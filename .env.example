# ── App ──────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=

# ── Qdrant ───────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=manufacturing_risk

# ── Ingestion ────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536